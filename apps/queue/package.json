{
  "name": "@pegada/queue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "eslintConfig": {
    "root": true,
    "extends": [
      "@pegada/eslint-config/typescript"
    ],
    "parserOptions": {
      "project": "./tsconfig.json"
    }
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "format:fix": "prettier --write . --ignore-path ../../.gitignore",
    "start": "bun dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "npx rimraf dist && tsup --sourcemap",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@pegada/eslint-config": "workspace:*",
    "@pegada/prettier-config": "workspace:*",
    "prettier": "^3.8.3"
  },
  "prettier": "@pegada/prettier-config",
  "dependencies": {
    "@fastify/http-proxy": "^9.5.0",
    "@pegada/api": "workspace:*",
    "@pegada/shared": "workspace:*",
    "@pegada/tsconfig": "workspace:*",
    "@tensorflow/tfjs-node": "^4.22.0",
    "blurhash": "^2.0.5",
    "bullmq": "^5.76.7",
    "expo-server-sdk": "^3.10.0",
    "fastify": "^4.28.1",
    "nsfwjs": "^4.3.0",
    "sharp": "^0.33.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "*"
  }
}
