# OSX
#
.DS_Store

# node.js
#
node_modules/
npm-debug.log
pnpm-error.log
.pnpm-debug.log*

# BUCK
buck-out/
\.buckd/
*.keystore


# Expo
.expo/*
expo-env.d.ts
web-build/

**/*/.expo

**/*/.next

**/*/ios
**/*/android

.turbo
build/**

.pnp.*
.pnpm/*
!.pnpm/patches
!.pnpm/plugins
!.pnpm/releases
!.pnpm/sdks
!.pnpm/versions

.env
.envrc

.env.dev
.env.prod

dist/
build/

# Metro
.metro*

# Notifications
GoogleService-Info.plist
google-services.json

# Turbo cache
*.tsbuildinfo
# EAS-generated local credentials (contains cert passwords) — never commit
credentials.json
credentials/

# Local Expo modules (modules/*) are handwritten native source, not CNG
# output -- re-include them from the **/*/ios and **/*/android rules above,
# but keep their gradle build output ignored.
!modules/*/ios/
!modules/*/ios/**
!modules/*/android/
!modules/*/android/**
modules/*/android/build/
