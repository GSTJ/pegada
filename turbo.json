{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env", ".env"],
  "tasks": {
    "test": {
      "outputs": ["node_modules/.cache/.testcache"]
    },
    "typecheck": {
      "outputs": ["node_modules/.cache/tsbuildinfo.json"]
    },
    "build": {
      "outputs": ["node_modules/.cache/build.json"]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    }
  }
}
