    "@types/jest": "^29.5.12",
    "bullmq": "^5.76.7",
    "date-fns": "^3.6.0",
    "geolib": "^3.3.14",
    "handlebars": "^4.7.9",
    "i18next": "^23.12.2",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.14",
    "posthog-node": "^4.0.1",
    "semver": "^7.8.0",
    "superjson": "^2.2.6",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "zod": "3.23.8"
